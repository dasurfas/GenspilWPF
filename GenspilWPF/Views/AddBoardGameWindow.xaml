<Window x:Class="GenspilWPF.Views.AddBoardGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GenspilWPF.Views"
        mc:Ignorable="d"
        Title="Tilføj spil" Height="400" Width="440"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="9.5*"/>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="12*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>
        <!-- Overskrift -->
        <Grid Grid.Row="0">
            <TextBlock x:Name="HeaderTextBlock" Text="Tilføj nyt spil" FontSize="12" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,2,8,0"/>
        </Grid>
        <!-- Titel -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,8,8,8">
            <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                <TextBlock Text="* Obligatoriske felter" VerticalAlignment="Center" FontSize="8" HorizontalAlignment="Left" Margin="0,0,8,0"/>
                <TextBlock Text="Titel *" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <TextBox Width="200" HorizontalAlignment="Left" Height="25" x:Name="TitleTextBox" Tag="Fx Catan..."/>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="" VerticalAlignment="Center" FontSize="8" HorizontalAlignment="Left" Margin="0,0,8,0"/>
                <TextBlock Text="Status" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <ComboBox Width="200" HorizontalAlignment="Left" Height="25" x:Name="StatusComboBox"/>
            </StackPanel>
        </StackPanel>
        <!-- Genre og antal spillere -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,8,8,8">
            <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                <TextBlock Text="Genre *" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <TextBox Width="200" HorizontalAlignment="Left" Height="25" x:Name="GenreTextBox" Tag="Fx Strategi..."/>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Antal spillere *" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <TextBox Width="200" HorizontalAlignment="Left" Height="25" x:Name="PlayersTextBox" Tag="Fx 2 eller 3-4..."/>
            </StackPanel>
        </StackPanel>
        <!-- Stand og pris -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="8,8,8,8">
            <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                <TextBlock Text="Stand *" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <ComboBox Width="200" HorizontalAlignment="Left" Height="25" x:Name="ConditionComboBox"/>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Pris *" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <TextBox Width="200" HorizontalAlignment="Left" Height="25" x:Name="PriceTextBox" Tag="Kr..."/>
            </StackPanel>
        </StackPanel>
        <!-- Noter -->
        <StackPanel Grid.Row="4" Orientation="Vertical" Margin="8,8,8,8">
            <TextBlock Text="Noter" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
            <TextBox Width="408" HorizontalAlignment="Left" Height="50" x:Name="NotesTextBox" AcceptsReturn="True" TextWrapping="Wrap"/>
        </StackPanel>
        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,8,8">
            <Button Content="Annuller" x:Name="CancelButton" Background="Transparent" BorderBrush="#0C447C" BorderThickness="1" Foreground="#0C447C"  Margin="0,0,8,0" Click="CancelButton_Click" IsCancel="True"/>
            <Button Content="Tilføj spil" x:Name="AddButton" Margin="0,0,8,0" Click="AddButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
