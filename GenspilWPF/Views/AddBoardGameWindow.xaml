<Window x:Class="GenspilWPF.Views.AddBoardGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GenspilWPF.Views"
        mc:Ignorable="d"
        Title="AddBoardGameWindow" Height="360" Width="440">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30*"/>
            <RowDefinition Height="95*"/>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="120*"/>
            <RowDefinition Height="50*"/>
        </Grid.RowDefinitions>
        <!-- Overskrift -->
        <Grid Grid.Row="0">
            <TextBlock Text="Tilføj nyt spil" FontSize="12" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,2,8,0"/>
        </Grid>
        <!-- Titel -->
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="8,8,8,8">
            <TextBlock Text="* Obligatoriske felter" VerticalAlignment="Center" FontSize="8" HorizontalAlignment="Left" Margin="0,0,8,0"/>
            <TextBlock Text="Titel *" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
            <TextBox Width="408" HorizontalAlignment="Left" Height="20" x:Name="TitleTextBox"/>
        </StackPanel>
        <!-- Genre og antal spillere -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,8,8,8">
            <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                <TextBlock Text="Genre *" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <TextBox Width="200" HorizontalAlignment="Left" Height="20" x:Name="GenreTextBox"/>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Antal spillere *" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <TextBox Width="200" HorizontalAlignment="Left" Height="20" x:Name="PlayersTextBox"/>
            </StackPanel>
        </StackPanel>
        <!-- Stand og pris -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="8,8,8,8">
            <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                <TextBlock Text="Stand *" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <ComboBox Width="200" HorizontalAlignment="Left" Height="20" x:Name="ConditionComboBox"/>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Pris *" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <TextBox Width="200" HorizontalAlignment="Left" Height="20" x:Name="PriceTextBox"/>
            </StackPanel>
        </StackPanel>
        <!-- Noter -->
        <StackPanel Grid.Row="4" Orientation="Vertical" Margin="8,8,8,8">
            <TextBlock Text="Noter" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
            <TextBox Width="408" HorizontalAlignment="Left" Height="50" x:Name="NotesTextBox" AcceptsReturn="True" TextWrapping="Wrap"/>
        </StackPanel>
        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,8,8" Width="168">
            <Button Content="Annuller" Width="80" x:Name="CancelButton" Height="20" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Content="Tilføj spil" x:Name="AddButton" Width="80" Height="20" Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
