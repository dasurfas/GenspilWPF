<Window x:Class="GenspilWPF.Views.AddReservationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GenspilWPF.Views"
        mc:Ignorable="d"
        Title="Tilføj reservation" Height="400" Width="440"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="9.5*"/>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="12*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>
        <!-- Overskrift -->
        <Grid Grid.Row="0">
            <TextBlock x:Name="HeaderTextBlock" Text="Ny Kundeforespørgsel" FontSize="12" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,2,8,0"/>
        </Grid>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,8,8,8">
            <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                <TextBlock Text="* Obligatoriske felter" VerticalAlignment="Center" FontSize="8" HorizontalAlignment="Left" Margin="0,0,8,0"/>
                <TextBlock Text="Spil titel *" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <TextBox Width="200" HorizontalAlignment="Left" Height="25" x:Name="TitleTextBox" Tag="Fx Matador..."/>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                <TextBlock Text="" VerticalAlignment="Center" FontSize="8" HorizontalAlignment="Left" Margin="0,0,8,0"/>
                <TextBlock Text="Status" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <ComboBox Width="200" HorizontalAlignment="Left" Height="25" x:Name="StatusComboBox"/>
            </StackPanel>
        </StackPanel>
        <!-- Kunde info -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,8,8,8">
            <StackPanel Orientation="Vertical" Margin="0,0,8,0">
                <TextBlock Text="Navn *" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <TextBox Width="200" HorizontalAlignment="Left" Height="25" x:Name="CustomerTextBox" Tag="Fx Lars Nielsen..."/>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Kontakt *" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
                <TextBox Width="200" HorizontalAlignment="Left" Height="25" x:Name="ContactInfoTextBox" Tag="Fx telefon eller email..."/>
            </StackPanel>
        </StackPanel>
        <!-- Noter -->
        <StackPanel Grid.Row="3" Orientation="Vertical" Margin="8,8,8,8">
            <TextBlock Text="Noter" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,2,8,0"/>
            <TextBox Width="408" HorizontalAlignment="Left" Height="70" x:Name="NotesTextBox" AcceptsReturn="True" TextWrapping="Wrap"/>
        </StackPanel>
        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,8,8" Width="168">
            <Button Content="Annuller" Width="80" x:Name="CancelButton" Height="25" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Content="Reserver" x:Name="AddButton" Width="80" Height="25" Margin="0,0,8,0" Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
