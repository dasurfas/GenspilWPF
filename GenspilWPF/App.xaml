<Application x:Class="GenspilWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:vm="clr-namespace:GenspilWPF.ViewModels"
             xmlns:views="clr-namespace:GenspilWPF.Views"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GenspilWPF"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <DataTemplate DataType="{x:Type vm:BoardGameViewModel}">
            <views:BoardGameView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReservationViewModel}">
            <views:ReservationView/>
        </DataTemplate>
    </Application.Resources>
</Application>